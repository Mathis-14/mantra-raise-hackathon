# Gemini API — Computer Use (playtest) + Veo (creatives). Get one per teammate if rate-limited.
GEMINI_API_KEY=

# NVIDIA NIM — multimodal gameplay comparison (video + embedded audio).
# Server/worker only. Defaults target the hosted NVIDIA API and Nemotron Omni.
NVIDIA_API_KEY=
NVIDIA_API_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_GAMEPLAY_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Supabase — single source of truth for pipeline state + realtime dashboard feed.
# Browser-safe (dashboard reads via RLS-guarded SELECT):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server/worker only — full write access, NEVER exposed to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# Where the dashboard runs (used by the worker to link screenshots/events).
NEXT_PUBLIC_APP_URL=http://localhost:3000
