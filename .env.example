# Gemini API — Computer Use (playtest) + Veo (creatives). Get one per teammate if rate-limited.
GEMINI_API_KEY=

# Supabase — single source of truth for pipeline state + realtime dashboard feed.
# Browser-safe (dashboard reads via RLS-guarded SELECT):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server/worker only — full write access, NEVER exposed to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# Where the dashboard runs (used by the worker to link screenshots/events).
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Where the variant-aware game runtime runs for persisted phone previews.
# Start with: npm run game -- --port 5174
VARIANT_GAME_URL=http://localhost:5174
