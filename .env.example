# Gemini API — Computer Use (playtest) + Veo (creatives). Get one per teammate if rate-limited.
GEMINI_API_KEY=

# Supabase — single source of truth for pipeline state + realtime dashboard feed.
# Browser-safe (dashboard reads via RLS-guarded SELECT):
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server/worker only — full write access, NEVER exposed to the browser:
SUPABASE_SERVICE_ROLE_KEY=

# Google Ads — server/worker only. Target must be a non-manager test child.
# The credential JSON stays outside the repository.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_LOGIN_CUSTOMER_ID=
GOOGLE_ADS_CUSTOMER_ID=

# Where the dashboard runs (used by the worker to link screenshots/events).
NEXT_PUBLIC_APP_URL=http://localhost:3000
