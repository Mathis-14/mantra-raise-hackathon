# NVIDIA NIM (build.nvidia.com) — used for VLM + Nemotron 3 calls.
# Copy this file to .env and fill the key. .env is gitignored.
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1

# Model ids (override if NVIDIA renames them).
VLM_MODEL=qwen/qwen2.5-vl-72b-instruct
NEMOTRON_MODEL=nvidia/nemotron-3-super-120b-a12b
